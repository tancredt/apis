#!/usr/bin/env python3
"""
Test script for PDF endpoints with filters.

Tests the detectors PDF endpoint with various filter combinations,
specifically testing the AreaRAE Plus filter in Location order.

Usage:
    python test_pdf_endpoint.py
    
    Or with custom credentials:
    python test_pdf_endpoint.py --username admin --password admin
    
    Or with custom URL:
    python test_pdf_endpoint.py --url http://localhost:8000
"""

import os
import sys
import argparse
import requests
from pathlib import Path
from datetime import datetime


BASE_DIR = Path(__file__).parent
PDF_OUTPUT_DIR = BASE_DIR / "pdf_test_output"


def login(session, base_url, username, password):
    """Login and return session with cookies."""
    print(f"Logging in as '{username}'...")
    
    # First get CSRF token
    csrf_response = session.get(f"{base_url}/api/inventory/csrf-token/")
    if csrf_response.status_code != 200:
        print(f"  Warning: Could not get CSRF token ({csrf_response.status_code})")
        csrf_token = ""
    else:
        csrf_token = csrf_response.json().get('csrfToken', '')
        print(f"  Got CSRF token: {csrf_token[:10]}...")
    
    # Login
    login_response = session.post(
        f"{base_url}/api/inventory/auth/login/",
        json={"username": username, "password": password},
        headers={"X-CSRFToken": csrf_token}
    )
    
    if login_response.status_code == 200:
        data = login_response.json()
        if data.get('success'):
            print(f"  ✓ Login successful!")
            return True
        else:
            print(f"  ✗ Login failed: {data.get('message', 'Unknown error')}")
    else:
        print(f"  ✗ Login failed with status {login_response.status_code}")
        print(f"    Response: {login_response.text[:200]}")
    
    return False


def get_detector_model_id(session, base_url, model_name):
    """Get the detector model ID by name."""
    print(f"Looking up detector model: {model_name}...")
    
    response = session.get(
        f"{base_url}/api/inventory/detectormodels/",
        params={"label": model_name}
    )
    
    if response.status_code == 200:
        data = response.json()
        if data:
            model_id = data[0]['id']
            label = data[0]['label']
            print(f"  ✓ Found: ID={model_id}, Label={label}")
            return model_id
        else:
            print(f"  ✗ No detector model found with name '{model_name}'")
    else:
        print(f"  ✗ Failed to get detector models: {response.status_code}")
    
    return None


def download_pdf(session, base_url, endpoint, output_file, description):
    """Download a PDF and report results."""
    url = f"{base_url}{endpoint}"
    
    print(f"\nTest: {description}")
    print(f"  URL: {url}")
    print(f"  Output: {output_file}")
    
    try:
        response = session.get(url, stream=True)
        
        if response.status_code == 200:
            # Save the PDF
            with open(output_file, 'wb') as f:
                for chunk in response.iter_content(chunk_size=8192):
                    f.write(chunk)
            
            file_size = output_file.stat().st_size
            print(f"  ✓ Success! PDF size: {file_size:,} bytes")
            return True
        else:
            print(f"  ✗ Failed with status {response.status_code}")
            print(f"    Response: {response.text[:500]}")
            return False
            
    except Exception as e:
        print(f"  ✗ Error: {e}")
        return False


def main():
    parser = argparse.ArgumentParser(description='Test PDF endpoints with filters')
    parser.add_argument('--username', default='admin', help='Username for login')
    parser.add_argument('--password', default='password', help='Password for login')
    parser.add_argument('--url', default='http://localhost:8000', help='Base URL')
    parser.add_argument('--model', default='AreaRAE Plus', help='Detector model to filter')
    args = parser.parse_args()
    
    print("=" * 70)
    print("PDF Endpoint Filter Test")
    print("=" * 70)
    print(f"Base URL: {args.url}")
    print(f"Filter Model: {args.model}")
    print()
    
    # Create output directory
    PDF_OUTPUT_DIR.mkdir(exist_ok=True)
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    
    # Create session
    session = requests.Session()
    
    # Login
    if not login(session, args.url, args.username, args.password):
        print("\nExiting: Login failed")
        sys.exit(1)
    
    print()
    
    # Get detector model ID
    model_id = get_detector_model_id(session, args.url, args.model)
    
    # Test cases
    tests = []
    
    # Test 1: All detectors
    tests.append({
        'endpoint': '/api/inventory/pdf/detectors/',
        'output': PDF_OUTPUT_DIR / f"detectors_all_{timestamp}.pdf",
        'description': 'All Detectors (no filters)'
    })
    
    # Test 2: Filter by AreaRAE Plus (by model ID if available)
    if model_id:
        tests.append({
            'endpoint': f'/api/inventory/pdf/detectors/?detector_model={model_id}&_t={timestamp}',
            'output': PDF_OUTPUT_DIR / f"detectors_{args.model.replace(' ', '_')}_{timestamp}.pdf",
            'description': f'{args.model} Only (by model ID={model_id})'
        })
    
    # Test 3: Filter by search term
    tests.append({
        'endpoint': f'/api/inventory/pdf/detectors/?search={args.model.split()[0]}&_t={timestamp}',
        'output': PDF_OUTPUT_DIR / f"detectors_{args.model.replace(' ', '_')}_search_{timestamp}.pdf",
        'description': f'{args.model} Only (by search term)'
    })
    
    # Test 4: Filter by status
    tests.append({
        'endpoint': f'/api/inventory/pdf/detectors/?status=OP&_t={timestamp}',
        'output': PDF_OUTPUT_DIR / f"detectors_operational_{timestamp}.pdf",
        'description': 'Operational Detectors Only'
    })
    
    # Test 5: Combined filters
    if model_id:
        tests.append({
            'endpoint': f'/api/inventory/pdf/detectors/?detector_model={model_id}&status=OP&_t={timestamp}',
            'output': PDF_OUTPUT_DIR / f"detectors_{args.model.replace(' ', '_')}_operational_{timestamp}.pdf",
            'description': f'{args.model} + Operational'
        })
    
    # Test 6: Exclude decommissioned
    tests.append({
        'endpoint': f'/api/inventory/pdf/detectors/?show_decommissioned=false&_t={timestamp}',
        'output': PDF_OUTPUT_DIR / f"detectors_no_decommissioned_{timestamp}.pdf",
        'description': 'Exclude Decommissioned'
    })
    
    # Run tests
    print("\n" + "=" * 70)
    print("Running Tests")
    print("=" * 70)
    
    results = []
    for test in tests:
        success = download_pdf(
            session,
            args.url,
            test['endpoint'],
            test['output'],
            test['description']
        )
        results.append((test['description'], success, test['output']))
    
    # Summary
    print("\n" + "=" * 70)
    print("Test Summary")
    print("=" * 70)
    
    passed = sum(1 for _, success, _ in results if success)
    total = len(results)
    
    for description, success, output_file in results:
        status = "✓ PASS" if success else "✗ FAIL"
        print(f"{status}: {description}")
        if success:
            print(f"       -> {output_file}")
    
    print()
    print(f"Results: {passed}/{total} tests passed")
    print()
    print(f"PDFs saved to: {PDF_OUTPUT_DIR}")
    print()
    
    if passed > 0:
        print("To view a PDF:")
        print(f"  evince {results[1][2] if model_id else results[0][2]}")
        print("  or")
        print("  open <pdf_file>  # macOS")
    
    sys.exit(0 if passed == total else 1)


if __name__ == '__main__':
    main()
